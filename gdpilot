#!/usr/bin/env python3
"""GodotPilot CLI — remote control for a running Godot game.

Connects to GodotPilot.cs TCP server, sends a command, prints the result.
No dependencies beyond Python stdlib.
"""

import argparse
import json
import os
import socket
import subprocess
import sys
import time


DEFAULT_HOST = "127.0.0.1"
DEFAULT_PORT = 6550
# Default socket timeout (seconds). Bumped from the original 10s because
# some server-side commands (notably project-specific game commands that
# walk a SQLite save layer or instantiate large scenes) take longer than
# that under cold-cache conditions. The cost of a higher default is paid
# only on actual failure (when the game isn't running) — the common path
# returns in milliseconds.
TIMEOUT = 60.0
PROJECT_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))


def _scan_godot_candidates() -> list[tuple[str, str]]:
    """Scan for all Godot binaries on this machine.

    Returns list of (path, source) tuples, ordered by preference.
    Source describes where it was found (for user feedback).
    """
    import glob
    import platform
    import shutil

    found = []

    # 1. GODOT_BIN env var
    env = os.environ.get("GODOT_BIN")
    if env:
        expanded = os.path.expanduser(env)
        if os.path.isfile(expanded):
            found.append((expanded, "GODOT_BIN env var"))

    # 2. .godot_bin project config
    config = os.path.join(PROJECT_DIR, ".godot_bin")
    if os.path.isfile(config):
        with open(config) as f:
            path = os.path.expanduser(f.read().strip())
        if os.path.isfile(path):
            found.append((path, f".godot_bin config"))

    # 3. PATH lookup
    for name in ("godot", "godot4"):
        p = shutil.which(name)
        if p:
            found.append((p, f"'{name}' on PATH"))

    # 4. Platform-specific common locations
    home = os.path.expanduser("~")
    system = platform.system()

    if system == "Linux":
        # Unpacked tarballs in home dir (official download pattern)
        for pattern in ("~/Godot_v*/Godot_v*", "~/godot/Godot_v*"):
            for c in sorted(glob.glob(os.path.expanduser(pattern)), reverse=True):
                if os.path.isfile(c) and os.access(c, os.X_OK):
                    found.append((c, "home directory"))
        # Flatpak
        flatpak = shutil.which("flatpak")
        if flatpak:
            for app_id in ("org.godotengine.GodotMono", "org.godotengine.Godot"):
                fp_path = f"/var/lib/flatpak/exports/bin/{app_id}"
                if os.path.isfile(fp_path):
                    found.append((fp_path, f"flatpak ({app_id})"))
        # Snap
        for p in ("/snap/bin/godot", "/snap/bin/godot4"):
            if os.path.isfile(p):
                found.append((p, "snap"))

    elif system == "Darwin":
        # macOS: /Applications, Homebrew
        for pattern in (
            "/Applications/Godot_mono.app/Contents/MacOS/Godot",
            "/Applications/Godot.app/Contents/MacOS/Godot",
            f"{home}/Applications/Godot_mono.app/Contents/MacOS/Godot",
        ):
            for c in glob.glob(pattern):
                if os.path.isfile(c):
                    found.append((c, "Applications"))

    elif system == "Windows":
        # Windows: common install locations
        for pattern in (
            os.path.expandvars(r"%LOCALAPPDATA%\Godot\Godot_v*\Godot_v*.exe"),
            r"C:\Godot\Godot_v*.exe",
            os.path.join(home, "Godot_v*", "Godot_v*.exe"),
            os.path.expandvars(r"%PROGRAMFILES%\Godot\Godot_v*.exe"),
        ):
            for c in sorted(glob.glob(pattern), reverse=True):
                if os.path.isfile(c):
                    found.append((c, "local install"))
        # Scoop
        scoop = os.path.join(home, "scoop", "shims", "godot.exe")
        if os.path.isfile(scoop):
            found.append((scoop, "scoop"))

    # Deduplicate by resolved path, keep first occurrence (highest priority)
    seen = set()
    deduped = []
    for path, source in found:
        real = os.path.realpath(path)
        if real not in seen:
            seen.add(real)
            deduped.append((path, source))

    return deduped


def _find_godot_binary() -> str:
    """Return the best Godot binary, or empty string."""
    candidates = _scan_godot_candidates()
    return candidates[0][0] if candidates else ""


GODOT_BIN = _find_godot_binary()


def send_command(host: str, port: int, cmd: str, args: dict | None = None) -> dict:
    """Connect, send command, read response, disconnect."""
    payload = {"cmd": cmd}
    if args:
        payload["args"] = args

    with socket.create_connection((host, port), timeout=TIMEOUT) as sock:
        sock.sendall((json.dumps(payload) + "\n").encode())
        # Read until newline
        buf = b""
        while b"\n" not in buf:
            chunk = sock.recv(4096)
            if not chunk:
                break
            buf += chunk

    line = buf.decode().strip()
    if not line:
        return {"ok": False, "error": "Empty response from game"}
    return json.loads(line)


def die(msg: str) -> None:
    """Print error to both stderr (human) and stdout (agent JSON), then exit 1."""
    print(msg, file=sys.stderr)
    print(json.dumps({"ok": False, "error": msg}))
    sys.exit(1)


def emit(result: dict, pretty: bool) -> None:
    """Print result JSON to stdout. Always JSON, one line unless pretty."""
    if pretty:
        print(json.dumps(result, indent=2))
    else:
        print(json.dumps(result))


# ── Subcommand handlers ──────────────────────────────────────────────


def cmd_screenshot(args, host, port, pretty):
    result = send_command(host, port, "screenshot", {"max_width": args.max_width})
    if not result.get("ok", True):
        die(result.get("error", "screenshot failed"))
    emit(result, pretty)


def cmd_click(args, host, port, pretty):
    x, y = args.x, args.y
    # If --from-screenshot, scale coords from screenshot resolution to viewport resolution
    if args.from_screenshot:
        vp = send_command(host, port, "viewport_info")
        if vp.get("ok", True) and "viewport_width" in vp:
            # Screenshot is always max_width=1280 by default
            screenshot_w = args.from_screenshot
            scale = vp["viewport_width"] / screenshot_w
            x *= scale
            y *= scale
    result = send_command(host, port, "click", {
        "x": x, "y": y, "button": args.button,
    })
    emit(result, pretty)


