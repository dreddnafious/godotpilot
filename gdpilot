def cmd_invoke(args, host, port, pretty):
    """Invoke a method on a node (target = /path) or static type (target = TypeName).

    Positional `args` are parsed in this order: bool, null, int, float,
    JSON object/array (anything starting with `{` or `[`), then string
    fallback. The JSON path lets you call methods that take complex
    parameter types (records, classes, lists, dictionaries) by passing
    a JSON literal on the command line. The server-side reflection layer
    deserializes via the autoload's InvokeJsonOptions, which handles
    polymorphic types declared with [JsonDerivedType] automatically.

    Examples:
        # Primitive args
        gdpilot invoke /root/PartyManager AddItem healing_potion 1 true

        # Complex arg — pass an ActiveBuff record as JSON
        gdpilot invoke /root/PartyManager ApplyBuff \\
            '{"id":"stoneskin","effect":{"$type":"ac","Bonus":2},"lifetime":"Tick","RemainingTicks":10}'
    """
    a = {"target": args.target, "method": args.method}
    if args.args:
        method_args = []
        for raw in args.args:
            method_args.append(_parse_invoke_arg(raw))
        a["args"] = method_args
    result = send_command(host, port, "invoke", a)
    emit(result, pretty)


def _parse_invoke_arg(raw):
    """Parse one positional invoke arg using the precedence:
    bool → null → int → float → JSON object/array → string."""
    lower = raw.lower()
    if lower in ("true", "false"):
        return lower == "true"
    if lower == "null":
        return None
    try:
        return int(raw)
    except ValueError:
        pass
    try:
        return float(raw)
    except ValueError:
        pass
    stripped = raw.strip()
    if stripped.startswith("{") or stripped.startswith("["):
        try:
            return json.loads(stripped)
        except json.JSONDecodeError:
            pass
    return raw


def cmd_wait(args, host, port, pretty):
    result = send_command(host, port, "wait", {"ms": args.ms})
    emit(result, pretty)


def cmd_game_cmd(args, host, port, pretty):
    """Run a registered game command via the 'cmd' subcommand."""
    cmd_args = {}
    if args.args:
        for pair in args.args:
            key, _, val = pair.partition("=")
            key = key.lstrip("-").replace("-", "_")
            # Try to parse as number/bool
            if val.lower() in ("true", "false"):
                cmd_args[key] = val.lower() == "true"
            else:
                try:
                    cmd_args[key] = int(val)
                except ValueError:
                    try:
                        cmd_args[key] = float(val)
                    except ValueError:
                        cmd_args[key] = val
    result = send_command(host, port, args.name, cmd_args)
    emit(result, pretty)


def cmd_console(args, host, port, pretty):
    """Run a console command string."""
    result = send_command(host, port, "run_console", {"command": args.command})
    emit(result, pretty)


def cmd_list(args, host, port, pretty):
    """List all registered commands."""
    result = send_command(host, port, "list_commands")
    emit(result, pretty)


def cmd_run(args, host, port, pretty):
    """Launch the game and wait for GodotPilot to be ready."""
    # Check if already running
    if _is_game_running(host, port):
        print("Game is already running.", file=sys.stderr)
        emit({"ok": True, "already_running": True}, pretty)
        return

    if not GODOT_BIN or not os.path.isfile(GODOT_BIN):
        die("Godot binary not found. Run 'gdpilot setup' to configure.")

    # Build C# solutions and re-import assets before launching.
    #
    # --build-solutions handles the chicken-and-egg case on a fresh install:
    # Godot tries to create autoloads in first_scan_filesystem, which runs
    # *before* dotnet_build_project — so on a project with no compiled .dll
    # yet, the autoload fails to load, the actual run hangs waiting for a
    # TCP server that never came up. Building first ensures the .dll exists
    # before the autoload is needed. Idempotent and fast on cache hit.
    if any(p.endswith(".csproj") for p in os.listdir(PROJECT_DIR)):
        print("Building C# solutions...", file=sys.stderr)
        subprocess.run(
            [GODOT_BIN, "--path", PROJECT_DIR, "--headless", "--build-solutions", "--quit"],
            capture_output=True, timeout=120,
        )

    # Reimport assets before launching (ensures new GLBs/PNGs are available)
    print("Importing assets...", file=sys.stderr)
    subprocess.run(
        [GODOT_BIN, "--path", PROJECT_DIR, "--headless", "--import"],
        capture_output=True, timeout=60,
    )

    cmd = [GODOT_BIN, "--path", PROJECT_DIR]
    if args.scene:
        cmd.append(args.scene)
    if args.verbose:
        cmd.append("--verbose")

    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL if not args.verbose else None,
        stderr=subprocess.DEVNULL if not args.verbose else None,
    )

    # Wait for TCP server to come up
    deadline = time.monotonic() + args.timeout
    while time.monotonic() < deadline:
        if proc.poll() is not None:
            die(f"Godot exited immediately with code {proc.returncode}")
        if _is_game_running(host, port):
            emit({"ok": True, "pid": proc.pid}, pretty)
            return
        time.sleep(0.3)

    die(f"Timed out waiting {args.timeout}s for GodotPilot on {host}:{port}")


def cmd_stop(args, host, port, pretty):
    """Send quit command to the running game."""
    try:
        result = send_command(host, port, "quit")
        emit(result, pretty)
    except (ConnectionRefusedError, OSError, socket.timeout, TimeoutError):
        print("Game is not running.", file=sys.stderr)
        emit({"ok": True, "already_stopped": True}, pretty)


def cmd_setup(args, host, port, pretty):
    """Scan for Godot binaries and write .godot_bin config."""
    candidates = _scan_godot_candidates()

    if not candidates:
        die(
            "No Godot binary found.\n"
            "Install Godot with C#/Mono support, then either:\n"
            "  - Add it to your PATH as 'godot' or 'godot4'\n"
            "  - Set the GODOT_BIN environment variable\n"
            "  - Run: echo '/path/to/godot' > .godot_bin"
        )

    # If --path was given explicitly, use that
    if args.path:
        expanded = os.path.expanduser(args.path)
        if not os.path.isfile(expanded):
            die(f"Not a file: {expanded}")
        chosen = expanded
    else:
        # Use the best candidate
        chosen = candidates[0][0]

    # Show what was found
    print("Godot binaries found:", file=sys.stderr)
    for i, (path, source) in enumerate(candidates):
        marker = " *" if path == chosen else "  "
        print(f"  {marker} {path}  ({source})", file=sys.stderr)

    # Write .godot_bin
    config_path = os.path.join(PROJECT_DIR, ".godot_bin")
    with open(config_path, "w") as f:
        f.write(chosen + "\n")
    print(f"\nWrote {config_path}", file=sys.stderr)

    emit({"ok": True, "godot_bin": chosen, "config": config_path}, pretty)


def _is_game_running(host: str, port: int) -> bool:
    try:
        with socket.create_connection((host, port), timeout=1.0) as sock:
            sock.sendall(b'{"cmd":"perf"}\n')
            data = sock.recv(4096)
            return bool(data)
    except (ConnectionRefusedError, OSError, socket.timeout):
        return False


# ── CLI setup ─────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        prog="gdpilot",
        description="Remote control for a running Godot game via GodotPilot",
    )
    parser.add_argument("--host", default=DEFAULT_HOST, help="GodotPilot host (default: 127.0.0.1)")
    parser.add_argument("--port", type=int, default=DEFAULT_PORT, help="GodotPilot port (default: 6550)")
    parser.add_argument("--pretty", action="store_true", help="Pretty-print JSON output")

    sub = parser.add_subparsers(dest="subcmd", help="Command to run")

    # screenshot
    p = sub.add_parser("screenshot", help="Capture viewport screenshot")
    p.add_argument("--max-width", type=int, default=1280, help="Max width in pixels (default: 1280)")

    # click
    p = sub.add_parser("click", help="Click at viewport coords; hit-tests UI buttons, falls back to PushInput for 3D")
    p.add_argument("x", type=float, help="X in viewport coordinates (or screenshot coords with --from-screenshot)")
    p.add_argument("y", type=float, help="Y in viewport coordinates (or screenshot coords with --from-screenshot)")
    p.add_argument("--button", type=int, default=1, help="Mouse button (1=left, 2=right, 3=middle)")
    p.add_argument("--from-screenshot", type=int, default=0, metavar="WIDTH",
                   help="Translate from screenshot resolution to viewport (e.g. 1280 → uniform *1.5)")

    # drag
    p = sub.add_parser("drag", help="Inject mouse drag")
    p.add_argument("x1", type=float, help="Start X")
    p.add_argument("y1", type=float, help="Start Y")
    p.add_argument("x2", type=float, help="End X")
    p.add_argument("y2", type=float, help="End Y")
    p.add_argument("--steps", type=int, default=10, help="Interpolation steps")
    p.add_argument("--button", type=int, default=1, help="Mouse button")

    # type
    p = sub.add_parser("type", help="Type text characters")
    p.add_argument("text", help="Text to type")
    p.add_argument("--submit", action="store_true", help="Press Enter after typing")

    # action
    p = sub.add_parser("action", help="Trigger input action")
    p.add_argument("name", help="Action name (e.g. camera_pan_up)")
    p.add_argument("--duration", type=int, default=100, help="Hold duration in ms")

    # tree
    p = sub.add_parser("tree", help="Dump scene tree")
    p.add_argument("--path", default=None, help="Root node path (default: /root)")
    p.add_argument("--depth", type=int, default=None, help="Max depth (default: 3)")

    # find
    p = sub.add_parser("find", help="Search nodes by name/type")
    p.add_argument("pattern", help="Name pattern to search")
    p.add_argument("--type", default=None, help="Filter by node type")

    # get
    p = sub.add_parser("get", help="Read a node property")
    p.add_argument("node_path", help="Node path")
    p.add_argument("property", help="Property name")

    # props
    p = sub.add_parser("props", help="Dump all properties on a node")
    p.add_argument("node_path", help="Node path")

    # signals
    p = sub.add_parser("signals", help="Inspect signal subscription graph")
    p.add_argument("--node", default=None, help="Limit to one node by path (default: walk /root recursively)")
    p.add_argument("--name", default=None, help="Filter signal names by case-insensitive substring")
    p.add_argument("--include-unconnected", action="store_true",
                   help="Include signals that have zero subscribers (default: only connected signals)")

    # describe
    p = sub.add_parser("describe", help="Walk public C# properties on a node and dump as JSON")
    p.add_argument("node_path", help="Node path")
    p.add_argument("--include-godot", action="store_true",
                   help="Include Godot framework properties (Node.name, position, etc.)")
    p.add_argument("--depth", type=int, default=None, help="Recursion depth for nested objects (0-3, default 1)")

    # set
    p = sub.add_parser("set", help="Write a node property")
    p.add_argument("node_path", help="Node path")
    p.add_argument("property", help="Property name")
    p.add_argument("value", help="Value to set (auto-parsed as number/bool/JSON object)")

    # sequence
    p = sub.add_parser("sequence", help="Overlapping input action sequence")
    p.add_argument("actions", nargs="*", help="Actions as name:start_ms:duration_ms (e.g. ui_up:0:500 ui_right:200:300)")
    p.add_argument("--json", default=None, help='JSON array: [{"name":"x","start_ms":0,"duration_ms":500}]')

    # click_node
    p = sub.add_parser("click_node", help="Click a UI element by text or node path")
    p.add_argument("--text", default=None, help="Find button/label containing this text")
    p.add_argument("--path", default=None, help="Node path to a Control")
    p.add_argument("--button", type=int, default=1, help="Mouse button (default: 1)")

    # hover
    p = sub.add_parser("hover", help="Move cursor to a position or UI element")
    p.add_argument("--text", default=None, help="Find control containing this text")
    p.add_argument("--path", default=None, help="Node path to a Control")
    p.add_argument("--x", type=float, default=None, help="Screen X coordinate")
    p.add_argument("--y", type=float, default=None, help="Screen Y coordinate")

    # viewport_info
    sub.add_parser("viewport_info", help="Get window/viewport resolution and scale factors")

    # perf
    sub.add_parser("perf", help="Show performance metrics")

    # log
    p = sub.add_parser("log", help="Read captured log output")
    p.add_argument("--source", choices=["buffer", "file"], default="buffer",
                   help="buffer (default, in-memory CaptureLog ring) or file (Godot log file tail)")
    p.add_argument("--clear", action="store_true", help="Clear buffer after reading (buffer source only)")
    p.add_argument("--tail", type=int, default=50, help="Number of lines to return (file source only, default 50)")

    # static
    p = sub.add_parser("static", help="Inspect static C# fields/properties on a type via reflection")
    p.add_argument("type", help="Fully qualified or short C# type name (e.g. 'OdeToTheBard.Data.DataLoader' or 'DataLoader')")
    p.add_argument("member", nargs="?", default=None,
                   help="Optional: single static field/property to inspect. Omitted = dump all public statics.")
    p.add_argument("--depth", type=int, default=None, help="Recursion depth for nested objects (0-3, default 1)")

    # invoke
    p = sub.add_parser("invoke", help="Invoke a method on a node or static type via reflection")
    p.add_argument("target", help="Node path (starts with /) or fully qualified type name for static methods")
    p.add_argument("method", help="Method name")
    p.add_argument("args", nargs="*", help="Method arguments — primitives auto-parsed (int/float/bool/string/null)")

    # wait
    p = sub.add_parser("wait", help="Wait for specified time")
    p.add_argument("ms", type=int, help="Milliseconds to wait")

    # cmd (game-specific)
    p = sub.add_parser("cmd", help="Run a registered game command")
    p.add_argument("name", help="Command name")
    p.add_argument("args", nargs="*", help="Arguments as key=value pairs (e.g. grid_x=5 grid_y=3)")

    # console
    p = sub.add_parser("console", help="Run a console command string")
    p.add_argument("command", help="Console command text")

    # list
    sub.add_parser("list", help="List all registered commands")

    # run
    p = sub.add_parser("run", help="Launch the game and wait for GodotPilot to be ready")
    p.add_argument("--timeout", type=float, default=30, help="Seconds to wait for game to start (default: 30)")
    p.add_argument("--verbose", action="store_true", help="Show Godot stdout/stderr")
    p.add_argument("--scene", default=None, help="Run a specific scene (e.g. res://scenes/main/Game.tscn)")

    # stop
    sub.add_parser("stop", help="Quit the running game")

    # setup
    p = sub.add_parser("setup", help="Find Godot binary and write .godot_bin config")
    p.add_argument("--path", default=None, help="Explicit path to Godot binary (skip scanning)")

    args = parser.parse_args()

    if not args.subcmd:
        parser.print_help()
        sys.exit(0)

    handler = {
        "screenshot": cmd_screenshot,
        "click": cmd_click,
        "drag": cmd_drag,
        "type": cmd_type,
        "action": cmd_action,
        "tree": cmd_tree,
        "find": cmd_find,
        "get": cmd_get,
        "props": cmd_props,
        "signals": cmd_signals,
        "describe": cmd_describe,
        "set": cmd_set,
        "sequence": cmd_sequence,
        "click_node": cmd_click_node,
        "hover": cmd_hover,
        "viewport_info": cmd_viewport_info,
        "perf": cmd_perf,
        "log": cmd_log,
        "static": cmd_static,
        "invoke": cmd_invoke,
        "wait": cmd_wait,
        "cmd": cmd_game_cmd,
        "console": cmd_console,
        "list": cmd_list,
        "run": cmd_run,
        "stop": cmd_stop,
        "setup": cmd_setup,
    }.get(args.subcmd)

    if not handler:
        die(f"Unknown subcommand: {args.subcmd}")

    # run and stop don't need an existing connection
    if args.subcmd in ("run", "stop", "setup"):
        handler(args, args.host, args.port, args.pretty)
        return

    try:
        handler(args, args.host, args.port, args.pretty)
    except ConnectionRefusedError:
        die(f"Cannot connect to GodotPilot at {args.host}:{args.port} — is the game running?")
    except socket.timeout:
        die(f"Connection to {args.host}:{args.port} timed out")
    except json.JSONDecodeError as e:
        die(f"Invalid response from game: {e}")


if __name__ == "__main__":
    main()
