def cmd_describe(args, host, port, pretty):
    a = {"node_path": args.node_path}
    if args.include_godot:
        a["include_godot"] = True
    if args.depth is not None:
        a["depth"] = args.depth
    result = send_command(host, port, "describe", a)
    emit(result, pretty)


def cmd_set(args, host, port, pretty):
    a = {"node_path": args.node_path, "property": args.property, "value": args.value}
    # Try to parse value as number/bool for proper JSON typing
    val = args.value
    if val.lower() in ("true", "false"):
        a["value"] = val.lower() == "true"
    elif val.startswith("{"):
        try:
            a["value"] = json.loads(val)
        except json.JSONDecodeError:
            pass
    else:
        try:
            a["value"] = int(val)
        except ValueError:
            try:
                a["value"] = float(val)
            except ValueError:
                pass
    result = send_command(host, port, "set", a)
    emit(result, pretty)


def cmd_sequence(args, host, port, pretty):
    """Send overlapping input action sequence."""
    actions = []
    if args.json:
        actions = json.loads(args.json)
    else:
        # Parse positional: name:start_ms:duration_ms name:start_ms:duration_ms ...
        for spec in args.actions:
            parts = spec.split(":")
            name = parts[0]
            start_ms = int(parts[1]) if len(parts) > 1 else 0
            duration_ms = int(parts[2]) if len(parts) > 2 else 500
            actions.append({"name": name, "start_ms": start_ms, "duration_ms": duration_ms})
    result = send_command(host, port, "sequence", {"actions": actions})
    emit(result, pretty)


def cmd_click_node(args, host, port, pretty):
