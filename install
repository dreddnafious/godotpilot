#!/usr/bin/env bash
# install — make a target directory ready to use godotpilot.
#
# Usage: install <target-dir> [--name NAME]
#
# Always: copies GodotPilot.cs and gdpilot into the target.
# If the target has no project.godot: scaffolds a fresh Godot 4.6 C# project
#   with the godotpilot autoload pre-registered. NAME defaults to "Project".
# If the target already has a project.godot: leaves it alone.
#
# Idempotent: re-run any time you update the canonical source. The file copy
# overwrites; the scaffold only runs once (it's gated on project.godot absence).
#
# The canonical source lives in this repo. Edits go here, then `install` pushes
# to consumers. Don't edit the copies in target projects — they get overwritten
# on the next install.

set -euo pipefail

NAME="Project"
TARGET=""

while [ $# -gt 0 ]; do
    case "$1" in
        --name)
            NAME="$2"
            shift 2
            ;;
        --name=*)
            NAME="${1#--name=}"
            shift
            ;;
        -h|--help)
            echo "Usage: $0 <target-dir> [--name NAME]" >&2
            exit 0
            ;;
        -*)
            echo "Unknown flag: $1" >&2
            echo "Usage: $0 <target-dir> [--name NAME]" >&2
            exit 1
            ;;
        *)
            if [ -z "$TARGET" ]; then
                TARGET="$1"
            else
                echo "Too many positional args" >&2
                exit 1
            fi
            shift
            ;;
    esac
done

if [ -z "$TARGET" ]; then
    echo "Usage: $0 <target-dir> [--name NAME]" >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── File copy (always) ───────────────────────────────────────────────────────

mkdir -p "$TARGET/scripts/core" "$TARGET/tools"
cp "$SCRIPT_DIR/GodotPilot.cs" "$TARGET/scripts/core/GodotPilot.cs"
cp "$SCRIPT_DIR/gdpilot" "$TARGET/tools/gdpilot"
chmod +x "$TARGET/tools/gdpilot"

# ── Scaffold (only if no project.godot exists) ───────────────────────────────

if [ -f "$TARGET/project.godot" ]; then
    echo "Installed godotpilot into $TARGET (existing project)" >&2
    echo "  scripts/core/GodotPilot.cs" >&2
    echo "  tools/gdpilot" >&2

    # Hint about autoload registration if it's not already wired up
    if ! grep -q '^GodotPilot=' "$TARGET/project.godot" 2>/dev/null; then
        echo "" >&2
        echo "Register the autoload in $TARGET/project.godot:" >&2
        echo "  [autoload]" >&2
        echo "  GodotPilot=\"*res://scripts/core/GodotPilot.cs\"" >&2
    fi
    exit 0
fi

# Fresh project — scaffold project.godot, .csproj, .sln
PROJECT_GUID=$(uuidgen | tr '[:lower:]' '[:upper:]')

cat > "$TARGET/project.godot" <<EOF
; Generated by godotpilot install. Edit freely after first launch.

config_version=5

[application]

config/name="$NAME"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")

[autoload]

GodotPilot="*res://scripts/core/GodotPilot.cs"

[dotnet]

project/assembly_name="$NAME"
EOF

cat > "$TARGET/$NAME.csproj" <<EOF
<Project Sdk="Godot.NET.Sdk/4.6.1">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>$NAME</RootNamespace>
  </PropertyGroup>
</Project>
EOF

cat > "$TARGET/$NAME.sln" <<EOF
Microsoft Visual Studio Solution File, Format Version 12.00
# Visual Studio 2012
Project("{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}") = "$NAME", "$NAME.csproj", "{$PROJECT_GUID}"
EndProject
Global
	GlobalSection(SolutionConfigurationPlatforms) = preSolution
		Debug|Any CPU = Debug|Any CPU
		ExportDebug|Any CPU = ExportDebug|Any CPU
		ExportRelease|Any CPU = ExportRelease|Any CPU
	EndGlobalSection
	GlobalSection(ProjectConfigurationPlatforms) = postSolution
		{$PROJECT_GUID}.Debug|Any CPU.ActiveCfg = Debug|Any CPU
		{$PROJECT_GUID}.Debug|Any CPU.Build.0 = Debug|Any CPU
		{$PROJECT_GUID}.ExportDebug|Any CPU.ActiveCfg = ExportDebug|Any CPU
		{$PROJECT_GUID}.ExportDebug|Any CPU.Build.0 = ExportDebug|Any CPU
		{$PROJECT_GUID}.ExportRelease|Any CPU.ActiveCfg = ExportRelease|Any CPU
		{$PROJECT_GUID}.ExportRelease|Any CPU.Build.0 = ExportRelease|Any CPU
	EndGlobalSection
EndGlobal
EOF

echo "Installed godotpilot into $TARGET (new project: $NAME)" >&2
echo "  scripts/core/GodotPilot.cs" >&2
echo "  tools/gdpilot" >&2
echo "  project.godot     (autoload registered)" >&2
echo "  $NAME.csproj" >&2
echo "  $NAME.sln" >&2
echo "" >&2
echo "Next: tools/gdpilot setup && tools/gdpilot run" >&2
