#!/usr/bin/env bash
# install — copy GodotPilot.cs and gdpilot into a target directory.
#
# Usage: install <target-dir>
#
# Idempotent: re-run any time you update the canonical source and want to push
# the latest version. Overwrites existing files at the destination.
#
# The canonical source lives in this repo. Edits go here, then `install` pushes
# to consumers. Don't edit the copies in target projects — they get overwritten
# on the next install.

set -euo pipefail

if [ $# -ne 1 ]; then
    echo "Usage: $0 <target-dir>" >&2
    exit 1
fi

TARGET="$1"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

mkdir -p "$TARGET/scripts/core" "$TARGET/tools"
cp "$SCRIPT_DIR/GodotPilot.cs" "$TARGET/scripts/core/GodotPilot.cs"
cp "$SCRIPT_DIR/gdpilot" "$TARGET/tools/gdpilot"
chmod +x "$TARGET/tools/gdpilot"

echo "Installed godotpilot into $TARGET" >&2
echo "  $TARGET/scripts/core/GodotPilot.cs" >&2
echo "  $TARGET/tools/gdpilot" >&2

# Hint about autoload registration if there's a project.godot to check.
# Not blocking — just informational, since the autoload registration is the one
# step the install can't do for you.
if [ -f "$TARGET/project.godot" ] && ! grep -q '^GodotPilot=' "$TARGET/project.godot" 2>/dev/null; then
    echo "" >&2
    echo "Register the autoload in $TARGET/project.godot:" >&2
    echo "  [autoload]" >&2
    echo "  GodotPilot=\"*res://scripts/core/GodotPilot.cs\"" >&2
fi
